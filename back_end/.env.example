# ===== .env 템플릿 (이 파일은 커밋됨 — 실제 값 넣지 말 것!) =====
# 실제 값은 back_end/.env(로컬) 또는 Render 대시보드(배포)에만 입력.
# 아래 <...> 자리표시자를 실제 값으로 바꿔서 .env 로 복사해 쓰세요.

# DB. 로컬은 docker-compose 기본값 그대로 OK. 배포는 Supabase 연결문자열.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/myblog

# JWT 서명 키 (필수). 생성: openssl rand -hex 32
JWT_SECRET=<여기에_랜덤_32바이트_hex>
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 관리자 계정 (필수)
ADMIN_USERNAME=<관리자_아이디>
ADMIN_PASSWORD=<강한_비밀번호>

# 프론트 오리진 (CORS). 배포 시 Vercel 도메인으로 교체.
FRONTEND_ORIGIN=http://localhost:3000
